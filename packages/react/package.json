{
  "name": "@command-palette/react",
  "version": "0.0.1",
  "description": "Unstyled React command palette primitives",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "command-palette",
    "command-menu",
    "react",
    "ui"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unvalley/command-palette.git"
  },
  "homepage": "https://github.com/unvalley/command-palette/tree/main/packages/react#readme",
  "bugs": {
    "url": "https://github.com/unvalley/command-palette/issues"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@command-palette/core": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsdown": "^0.21.8",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
